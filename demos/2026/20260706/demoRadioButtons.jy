from javax.swing import JPanel, JRadioButton, ButtonGroup

setScriptDescription('''Demo radio buttons''')

panel = JPanel()

group = ButtonGroup()

rb1 = JRadioButton("Red", True)   # initially selected
rb2 = JRadioButton("Green")
rb3 = JRadioButton("Blue")

group.add(rb1)
group.add(rb2)
group.add(rb3)

panel.add(rb1)
panel.add(rb2)
panel.add(rb3)

addTab('buttons',panel)
