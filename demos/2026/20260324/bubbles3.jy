from java.lang import Math

setScriptDescription('''Last demo created by ChatGPT.  Minor tweaks like
removing unicode arrows.''')
    
threshold = getParam(
    'threshold',
    0.42,
    'smaller &rarr; more merging, fatter blobs\nlarger &rarr; more separated blobs',
    { 'min': 0.20, 'max': 1.00 }
)

softness = getParam(
    'softness',
    0.08,
    'edge softness: smaller &rarr; sharper blobs, larger &rarr; mushier blobs',
    { 'min': 0.02, 'max': 0.20 }
)

driftScale = getParam(
    'driftScale',
    1.0,
    'multiplier for how much blobs wander around',
    { 'min': 0.0, 'max': 2.5 }
)

sizeScale = getParam(
    'sizeScale',
    1.0,
    'overall blob size multiplier',
    { 'min': 0.5, 'max': 2.0 }
)

glow = getParam(
    'glow',
    0.18,
    'internal brightness of blobs',
    { 'min': 0.0, 'max': 0.5 }
)

def makeLavaLampCube(nt, ny, nx, threshold, softness, driftScale, sizeScale, glow):

    blobs = [
        [0.25 * nx, 0.30 * ny, 1.00,  7.0, 2.0, 0.0,  7.0, 10.0, 1.0, 0.7],
        [0.55 * nx, 0.35 * ny, 0.95,  9.0, 2.5, 1.1,  9.0,  7.0, 0.8, 1.1],
        [0.72 * nx, 0.55 * ny, 0.90,  8.0, 2.0, 2.0,  6.0,  9.0, 1.2, 0.9],
        [0.40 * nx, 0.72 * ny, 1.05, 10.0, 3.0, 0.5,  8.0,  6.0, 0.9, 1.3],
        [0.68 * nx, 0.78 * ny, 0.85,  7.0, 1.8, 2.7,  5.0,  8.0, 1.1, 0.8]
    ]

    cube = []

    it = 0
    while it < nt:
        t = 2.0 * Math.PI * it / (nt - 1.0)
        plane = []

        iy = 0
        while iy < ny:
            row = []
            ix = 0
            while ix < nx:
                field = 0.0

                ib = 0
                while ib < len(blobs):
                    x0  = blobs[ib][0]
                    y0  = blobs[ib][1]
                    amp = blobs[ib][2]
                    r0  = blobs[ib][3]
                    dr  = blobs[ib][4]
                    ph  = blobs[ib][5]
                    dxm = blobs[ib][6]
                    dym = blobs[ib][7]
                    wx  = blobs[ib][8]
                    wy  = blobs[ib][9]

                    xc = x0 + driftScale * dxm * Math.cos(wx * t + ph)
                    yc = y0 + driftScale * dym * Math.sin(wy * t + 0.6 * ph)

                    r = sizeScale * (r0 + dr * (0.5 + 0.5 * Math.sin(t + ph)))

                    dx = ix - xc
                    dy = iy - yc

                    field = field + amp * Math.exp(-(dx * dx + dy * dy) / (2.0 * r * r))

                    ib = ib + 1

                z = 1.0 / (1.0 + Math.exp(-(field - threshold) / softness))
                z = z + glow * field

                row.append(z)
                ix = ix + 1

            plane.append(row)
            iy = iy + 1

        cube.append(plane)
        it = it + 1

    ds = dataset(cube)

    ds = putProperty(ds, QDataSet.DEPEND_0, findgen(nt))
    ds = putProperty(ds, QDataSet.DEPEND_1, findgen(ny))
    ds = putProperty(ds, QDataSet.DEPEND_2, findgen(nx))
    ds = putProperty(ds, QDataSet.TITLE, "Lava Lamp Demo (Parameterized)")

    return ds
    
nt = 70
ny = 90
nx = 110

ds = makeLavaLampCube(nt, ny, nx, threshold, softness, driftScale, sizeScale, glow)
plot(ds)
