# title: Read TIFF / GeoTIFF DEM
# label: TIFF / GeoTIFF DEM
#
# Reads a simple TIFF/GeoTIFF DEM using:
#   - TIFF IFD parsing
#   - vap+bin: for numeric reads
#   - GeoTIFF tags 33550 and 33922 when present
#   - .tfw fallback when GeoTIFF tags are absent
#
# Supports:
#   - strip TIFF
#   - tiled TIFF
#   - uncompressed
#   - one band
#
# Parameters:
#   resourceURI  URI or file to load
#   flipY        if true, reverse Y so it increases upward
#   tileIndex    for tiled TIFFs, optional tile number to read; -1 means stitch full image
#
# Limitations:
#   - compression not supported
#   - BigTIFF not supported
#   - multiband not supported
#   - only simple north-up georeferencing is interpreted

from java.io import File
from java.io import RandomAccessFile
from java.io import BufferedReader
from java.io import FileReader
from java.lang import Double
from org.das2.qds import DDataSet
from org.das2.qds import QDataSet

#resourceURI= getParam( 'resourceURI', 'https://github.com/GeoTIFF/test-data/blob/main/files/bremen_sea_ice_conc_2022_9_9.tif', 'example file to load' )
resourceURI= getParam( 'resourceURI', 'file:///home/jbf/ct/autoplot/data/image/davenport_w.zip/davenport_w.tif', 'example file to load' )
flipY      = getParam( "flipY", True, "Flip the  Y coordinates", [ True,False] )
tileIndex  = int( getParam( "tileIndex", "-1", "Tile index for tiled TIFF, -1 means full image" ) )

f = getFile(resourceURI)

def readUnsignedByte(raf):
    b = raf.read()
    if b < 0:
        raise Exception("unexpected EOF")
    return b

def readUnsignedShortLE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    return b0 | (b1 << 8)

def readUnsignedShortBE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    return (b0 << 8) | b1

def readUnsignedIntLE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    b2 = readUnsignedByte(raf)
    b3 = readUnsignedByte(raf)
    return long(b0) | (long(b1) << 8) | (long(b2) << 16) | (long(b3) << 24)

def readUnsignedIntBE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    b2 = readUnsignedByte(raf)
    b3 = readUnsignedByte(raf)
    return (long(b0) << 24) | (long(b1) << 16) | (long(b2) << 8) | long(b3)

def readLongLE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    b2 = readUnsignedByte(raf)
    b3 = readUnsignedByte(raf)
    b4 = readUnsignedByte(raf)
    b5 = readUnsignedByte(raf)
    b6 = readUnsignedByte(raf)
    b7 = readUnsignedByte(raf)
    return (long(b0)
        | (long(b1) << 8)
        | (long(b2) << 16)
        | (long(b3) << 24)
        | (long(b4) << 32)
        | (long(b5) << 40)
        | (long(b6) << 48)
        | (long(b7) << 56))

def readLongBE(raf):
    b0 = readUnsignedByte(raf)
    b1 = readUnsignedByte(raf)
    b2 = readUnsignedByte(raf)
    b3 = readUnsignedByte(raf)
    b4 = readUnsignedByte(raf)
    b5 = readUnsignedByte(raf)
    b6 = readUnsignedByte(raf)
    b7 = readUnsignedByte(raf)
    return ((long(b0) << 56)
        | (long(b1) << 48)
        | (long(b2) << 40)
        | (long(b3) << 32)
        | (long(b4) << 24)
        | (long(b5) << 16)
        | (long(b6) << 8)
        | long(b7))

def readUnsignedShort(raf, little):
    if little:
        return readUnsignedShortLE(raf)
    else:
        return readUnsignedShortBE(raf)

def readUnsignedInt(raf, little):
    if little:
        return readUnsignedIntLE(raf)
    else:
        return readUnsignedIntBE(raf)

def readLong(raf, little):
    if little:
        return readLongLE(raf)
    else:
        return readLongBE(raf)

def readDoubleValue(raf, little):
    bits = readLong(raf, little)
    print type(bits), bits
    return Double.longBitsToDouble(bits)

def typeSizeBytes(tiffType):
    if tiffType == 1:  return 1
    if tiffType == 2:  return 1
    if tiffType == 3:  return 2
    if tiffType == 4:  return 4
    if tiffType == 5:  return 8
    if tiffType == 6:  return 1
    if tiffType == 7:  return 1
    if tiffType == 8:  return 2
    if tiffType == 9:  return 4
    if tiffType == 10: return 8
    if tiffType == 11: return 4
    if tiffType == 12: return 8
    raise Exception("unsupported TIFF field type: " + str(tiffType))

def decodeInlineValues(fieldType, count, valueOffsetField, little):
    vals = []
    bytes4 = [0,0,0,0]
    tmp = long(valueOffsetField)

    if little:
        bytes4[0] = int(tmp & 255)
        bytes4[1] = int((tmp >> 8) & 255)
        bytes4[2] = int((tmp >> 16) & 255)
        bytes4[3] = int((tmp >> 24) & 255)
    else:
        bytes4[3] = int(tmp & 255)
        bytes4[2] = int((tmp >> 8) & 255)
        bytes4[1] = int((tmp >> 16) & 255)
        bytes4[0] = int((tmp >> 24) & 255)

    p = 0
    i = 0
    while i < count:
        if fieldType == 1 or fieldType == 6 or fieldType == 7:
            vals.append(bytes4[p])
            p = p + 1
        elif fieldType == 3 or fieldType == 8:
            if little:
                vals.append(bytes4[p] | (bytes4[p+1] << 8))
            else:
                vals.append((bytes4[p] << 8) | bytes4[p+1])
            p = p + 2
        elif fieldType == 4 or fieldType == 9:
            if little:
                vals.append(long(bytes4[0]) | (long(bytes4[1]) << 8) | (long(bytes4[2]) << 16) | (long(bytes4[3]) << 24))
            else:
                vals.append((long(bytes4[0]) << 24) | (long(bytes4[1]) << 16) | (long(bytes4[2]) << 8) | long(bytes4[3]))
            p = p + 4
        else:
            raise Exception("unsupported inline TIFF field type: " + str(fieldType))
        i = i + 1

    return vals

def readValuesAt(raf, little, tiffType, count, offset):
    vals = []
    raf.seek(offset)

    i = 0
    while i < count:
        if tiffType == 1 or tiffType == 6 or tiffType == 7:
            vals.append(readUnsignedByte(raf))
        elif tiffType == 3 or tiffType == 8:
            vals.append(readUnsignedShort(raf, little))
        elif tiffType == 4 or tiffType == 9:
            vals.append(readUnsignedInt(raf, little))
        elif tiffType == 12:
            vals.append(readDoubleValue(raf, little))
        else:
            raise Exception("unsupported TIFF field type: " + str(tiffType))
        i = i + 1

    return vals

def readIFDEntryValue(raf, little, fieldType, count, valueOffsetField):
    totalBytes = typeSizeBytes(fieldType) * count
    if totalBytes <= 4:
        return decodeInlineValues(fieldType, count, valueOffsetField, little)
    else:
        return readValuesAt(raf, little, fieldType, count, valueOffsetField)

def parseSimpleTIFF(tiffFile):
    neededTags = {}
    for t in [256,257,258,259,273,277,278,279,322,323,324,325,339,33550,33922]:
        neededTags[t] = 1

    raf = RandomAccessFile(tiffFile, "r")
    try:
        b0 = readUnsignedByte(raf)
        b1 = readUnsignedByte(raf)

        if b0 == 73 and b1 == 73:
            little = True
        elif b0 == 77 and b1 == 77:
            little = False
        else:
            raise Exception("not a TIFF file")

        magic = readUnsignedShort(raf, little)
        if magic == 43:
            raise Exception("BigTIFF is not supported")
        if magic != 42:
            raise Exception("unsupported TIFF magic number: " + str(magic))

        ifdOffset = readUnsignedInt(raf, little)
        raf.seek(ifdOffset)

        nentries = readUnsignedShort(raf, little)
        tags = {}

        i = 0
        while i < nentries:
            tag       = readUnsignedShort(raf, little)
            fieldType = readUnsignedShort(raf, little)
            count     = int(readUnsignedInt(raf, little))
            valueOff  = readUnsignedInt(raf, little)

            nextEntryPos = raf.getFilePointer()
            print 'read key ', tag, fieldType, count, valueOff

            if neededTags.has_key(tag):
                vals = readIFDEntryValue(raf, little, fieldType, count, valueOff)
                tags[tag] = vals

            raf.seek(nextEntryPos)
            i = i + 1

        info = {}
        info["little"] = little

        if not tags.has_key(256):
            raise Exception("TIFF tag 256 ImageWidth not found")
        if not tags.has_key(257):
            raise Exception("TIFF tag 257 ImageLength not found")

        info["width"]  = int(tags[256][0])
        info["length"] = int(tags[257][0])

        if tags.has_key(258):
            info["bitsPerSample"] = int(tags[258][0])
        else:
            info["bitsPerSample"] = 1

        if tags.has_key(259):
            info["compression"] = int(tags[259][0])
        else:
            info["compression"] = 1

        if tags.has_key(277):
            info["samplesPerPixel"] = int(tags[277][0])
        else:
            info["samplesPerPixel"] = 1

        if tags.has_key(339):
            info["sampleFormat"] = int(tags[339][0])
        else:
            info["sampleFormat"] = 1

        if tags.has_key(33550):
            info["modelPixelScale"] = tags[33550]
        else:
            info["modelPixelScale"] = None

        if tags.has_key(33922):
            info["modelTiepoint"] = tags[33922]
        else:
            info["modelTiepoint"] = None

        if tags.has_key(273):
            info["storage"] = "strips"
            info["stripOffsets"] = tags[273]
            if tags.has_key(279):
                info["stripByteCounts"] = tags[279]
            else:
                raise Exception("strip TIFF is missing tag 279 StripByteCounts")

            if tags.has_key(278):
                info["rowsPerStrip"] = int(tags[278][0])
            else:
                if len(tags[273]) == 1:
                    info["rowsPerStrip"] = info["length"]
                else:
                    info["rowsPerStrip"] = (info["length"] + len(tags[273]) - 1) / len(tags[273])

        elif tags.has_key(324):
            info["storage"] = "tiles"
            if not tags.has_key(322):
                raise Exception("tiled TIFF missing tag 322 TileWidth")
            if not tags.has_key(323):
                raise Exception("tiled TIFF missing tag 323 TileLength")
            if not tags.has_key(325):
                raise Exception("tiled TIFF missing tag 325 TileByteCounts")

            info["tileWidth"] = int(tags[322][0])
            info["tileLength"] = int(tags[323][0])
            info["tileOffsets"] = tags[324]
            info["tileByteCounts"] = tags[325]
        else:
            raise Exception("Neither strip tags nor tile tags found")

        return info
    finally:
        raf.close()

def mapToBinaryDataSourceType(bitsPerSample, sampleFormat):
    if sampleFormat == 1:
        if bitsPerSample == 8:
            return "ubyte"
        elif bitsPerSample == 16:
            return "ushort"
        elif bitsPerSample == 32:
            return "uint"
    elif sampleFormat == 2:
        if bitsPerSample == 8:
            return "byte"
        elif bitsPerSample == 16:
            return "short"
        elif bitsPerSample == 32:
            return "int"
    elif sampleFormat == 3:
        if bitsPerSample == 32:
            return "float"
        elif bitsPerSample == 64:
            return "double"

    raise Exception("unsupported sampleFormat=" + str(sampleFormat) + " bitsPerSample=" + str(bitsPerSample))

def bytesPerValue(dtype):
    if dtype == "byte":   return 1
    if dtype == "ubyte":  return 1
    if dtype == "short":  return 2
    if dtype == "ushort": return 2
    if dtype == "int":    return 4
    if dtype == "uint":   return 4
    if dtype == "float":  return 4
    if dtype == "double": return 8
    raise Exception("unsupported dtype: " + dtype)

def readWorldFile(tiffFile):
    path = tiffFile.getAbsolutePath()
    pl = path.lower()

    if pl.endswith(".tiff"):
        wpath = path[0:len(path)-5] + ".tfw"
    elif pl.endswith(".tif"):
        wpath = path[0:len(path)-4] + ".tfw"
    else:
        return None

    wf = File(wpath)
    if not wf.exists():
        return None

    br = BufferedReader(FileReader(wf))
    vals = []
    try:
        while True:
            line = br.readLine()
            if line == None:
                break
            line = line.strip()
            if line != "":
                vals.append(Double.parseDouble(line))
    finally:
        br.close()

    if len(vals) < 6:
        raise Exception("world file has fewer than 6 values: " + wpath)

    return vals

def readBlock(fileObj, offset, nx, nrows, dtype, little):
    recLength = nx * bytesPerValue(dtype)

    uri = "vap+bin:" + fileObj.toURI().toString()
    uri = uri + "?byteOffset=" + str(offset)
    uri = uri + "&rank2=:"
    uri = uri + "&recLength=" + str(recLength)
    uri = uri + "&type=" + dtype

    if little:
        uri = uri + "&byteOrder=little"
    else:
        uri = uri + "&byteOrder=big"

    ds = getDataSet(uri)

    if ds.length() != nrows:
        ds = ds[0:nrows,:]

    return ds

def copyInto(outds, startRow, inds):
    ny0 = inds.length()
    nx0 = inds.length(0)

    j = 0
    while j < ny0:
        i = 0
        while i < nx0:
            outds.putValue(startRow + j, i, inds.value(j, i))
            i = i + 1
        j = j + 1

def copyTileInto(outds, tileDs, x0, y0, nxTotal, nyTotal):
    tileNy = tileDs.length()
    tileNx = tileDs.length(0)

    j = 0
    while j < tileNy:
        yy = y0 + j
        if yy >= nyTotal:
            break
        i = 0
        while i < tileNx:
            xx = x0 + i
            if xx >= nxTotal:
                break
            outds.putValue(yy, xx, tileDs.value(j, i))
            i = i + 1
        j = j + 1

def makeXY(nx, ny, info, flipY, x0Shift, y0Shift):
    xds = DDataSet.createRank1(nx)
    yds = DDataSet.createRank1(ny)

    scale = info["modelPixelScale"]
    tie   = info["modelTiepoint"]

    if scale != None and tie != None and len(scale) >= 2 and len(tie) >= 6:
        sx = scale[0]
        sy = scale[1]

        i0 = tie[0]
        j0 = tie[1]
        x0 = tie[3]
        y0 = tie[4]

        i = 0
        while i < nx:
            xds.putValue(i, x0 + (x0Shift + i - i0) * sx)
            i = i + 1

        if flipY:
            j = 0
            while j < ny:
                # GeoTIFF north-up convention usually means model Y decreases as row increases
                yds.putValue(j, y0 - (y0Shift + (ny - 1 - j) - j0) * sy)
                j = j + 1
        else:
            j = 0
            while j < ny:
                yds.putValue(j, y0 - (y0Shift + j - j0) * sy)
                j = j + 1

    else:
        wf = readWorldFile(f)

        if wf != None:
            A = wf[0]
            D = wf[1]
            B = wf[2]
            E = wf[3]
            C = wf[4]
            F = wf[5]

            if abs(B) > 1e-12 or abs(D) > 1e-12:
                print "warning: rotated world file detected; using simple 1-D coordinates"

            i = 0
            while i < nx:
                xds.putValue(i, C + (x0Shift + i) * A)
                i = i + 1

            if flipY:
                j = 0
                while j < ny:
                    yds.putValue(j, F + (y0Shift + (ny - 1 - j)) * E)
                    j = j + 1
            else:
                j = 0
                while j < ny:
                    yds.putValue(j, F + (y0Shift + j) * E)
                    j = j + 1
        else:
            i = 0
            while i < nx:
                xds.putValue(i, x0Shift + i)
                i = i + 1

            if flipY:
                j = 0
                while j < ny:
                    yds.putValue(j, y0Shift + (ny - 1 - j))
                    j = j + 1
            else:
                j = 0
                while j < ny:
                    yds.putValue(j, y0Shift + j)
                    j = j + 1

    return [xds, yds]

info = parseSimpleTIFF(f)

nx             = info["width"]
ny             = info["length"]
bitsPerSample  = info["bitsPerSample"]
sampleFormat   = info["sampleFormat"]
compression    = info["compression"]
samplesPerPixel= info["samplesPerPixel"]
little         = info["little"]
storage        = info["storage"]

if compression != 1:
    raise Exception("compressed TIFF is not supported, compression=" + str(compression))

if samplesPerPixel != 1:
    raise Exception("only one-band TIFF is supported, samplesPerPixel=" + str(samplesPerPixel))

dtype = mapToBinaryDataSourceType(bitsPerSample, sampleFormat)

if storage == "strips":
    stripOffsets    = info["stripOffsets"]
    stripByteCounts = info["stripByteCounts"]
    rowsPerStrip    = info["rowsPerStrip"]

    if len(stripOffsets) != len(stripByteCounts):
        raise Exception("stripOffsets and stripByteCounts have different lengths")

    z = DDataSet.createRank2(ny, nx)

    row0 = 0
    s = 0
    while s < len(stripOffsets):
        offset = long(stripOffsets[s])
        nbytes = long(stripByteCounts[s])

        rowsThisStrip = rowsPerStrip
        if row0 + rowsThisStrip > ny:
            rowsThisStrip = ny - row0

        expectedBytes = long(rowsThisStrip) * long(nx) * long(bytesPerValue(dtype))
        if nbytes < expectedBytes:
            raise Exception("strip byte count too small for strip " + str(s))

        dsStrip = readBlock(f, offset, nx, rowsThisStrip, dtype, little)
        copyInto(z, row0, dsStrip)

        row0 = row0 + rowsThisStrip
        s = s + 1

    if flipY:
        z = z[::-1,:]

    xy = makeXY(nx, ny, info, flipY, 0, 0)
    xds = xy[0]
    yds = xy[1]

    z.putProperty(QDataSet.DEPEND_0, yds)
    z.putProperty(QDataSet.DEPEND_1, xds)
    z.putProperty(QDataSet.NAME, "geotiff")
    z.putProperty(QDataSet.LABEL, "GeoTIFF DEM")
    z.putProperty(QDataSet.TITLE, f.getName())

    result = z

elif storage == "tiles":
    tileWidth      = info["tileWidth"]
    tileLength     = info["tileLength"]
    tileOffsets    = info["tileOffsets"]
    tileByteCounts = info["tileByteCounts"]

    if len(tileOffsets) != len(tileByteCounts):
        raise Exception("tileOffsets and tileByteCounts have different lengths")

    tilesAcross = (nx + tileWidth - 1) / tileWidth
    tilesDown   = (ny + tileLength - 1) / tileLength
    expectedTiles = tilesAcross * tilesDown

    if len(tileOffsets) < expectedTiles:
        raise Exception("not enough tiles in TIFF: got " + str(len(tileOffsets)) + " expected " + str(expectedTiles))

    if tileIndex >= 0:
        if tileIndex >= len(tileOffsets):
            raise Exception("tileIndex out of range")

        tileX = tileIndex % tilesAcross
        tileY = tileIndex / tilesAcross

        x0 = tileX * tileWidth
        y0 = tileY * tileLength

        actualTileWidth = tileWidth
        if x0 + actualTileWidth > nx:
            actualTileWidth = nx - x0

        actualTileLength = tileLength
        if y0 + actualTileLength > ny:
            actualTileLength = ny - y0

        offset = long(tileOffsets[tileIndex])
        z = readBlock(f, offset, tileWidth, tileLength, dtype, little)
        z = z[0:actualTileLength,0:actualTileWidth]

        if flipY:
            z = z[::-1,:]

        xy = makeXY(actualTileWidth, actualTileLength, info, flipY, x0, y0)
        xds = xy[0]
        yds = xy[1]

        z.putProperty(QDataSet.DEPEND_0, yds)
        z.putProperty(QDataSet.DEPEND_1, xds)
        z.putProperty(QDataSet.NAME, "geotiff_tile")
        z.putProperty(QDataSet.LABEL, "GeoTIFF Tile " + str(tileIndex))
        z.putProperty(QDataSet.TITLE, f.getName())

        result = z

    else:
        z = DDataSet.createRank2(ny, nx)

        t = 0
        while t < expectedTiles:
            tileX = t % tilesAcross
            tileY = t / tilesAcross

            x0 = tileX * tileWidth
            y0 = tileY * tileLength

            actualTileWidth = tileWidth
            if x0 + actualTileWidth > nx:
                actualTileWidth = nx - x0

            actualTileLength = tileLength
            if y0 + actualTileLength > ny:
                actualTileLength = ny - y0

            offset = long(tileOffsets[t])
            tileDs = readBlock(f, offset, tileWidth, tileLength, dtype, little)
            tileDs = tileDs[0:actualTileLength,0:actualTileWidth]

            copyTileInto(z, tileDs, x0, y0, nx, ny)
            t = t + 1

        if flipY:
            z = z[::-1,:]

        xy = makeXY(nx, ny, info, flipY, 0, 0)
        xds = xy[0]
        yds = xy[1]

        z.putProperty(QDataSet.DEPEND_0, yds)
        z.putProperty(QDataSet.DEPEND_1, xds)
        z.putProperty(QDataSet.NAME, "geotiff")
        z.putProperty(QDataSet.LABEL, "GeoTIFF DEM")
        z.putProperty(QDataSet.TITLE, f.getName())

        result = z

else:
    raise Exception("unsupported storage type: " + storage)
    
