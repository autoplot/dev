#ds3= getDataSet('vap+cdaweb:ds=OMNI2_H0_MRG1HR&id=KP1800&timerange=Oct+2016')

formatDataSet(ds1,PWD+'data.sav')
formatDataSet(ds2,PWD+'data.sav?append=T')
formatDataSet(ds3,PWD+'data.sav?append=T')

