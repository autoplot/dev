ds2= getDataSet('https://cdaweb.gsfc.nasa.gov/sp_phys/data/omni/hourly/2016/omni2_h0_mrg1hr_20160701_v01.cdf?AE')
ds3= getDataSet('https://cdaweb.gsfc.nasa.gov/sp_phys/data/omni/hourly/2016/omni2_h0_mrg1hr_20160701_v01.cdf?KP')

#ds1= getDataSet('vap+cdaweb:ds=OMNI2_H0_MRG1HR&id=DST1800&timerange=Oct+2016')
